{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}"
            ],
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js"
            ],
            "preLaunchTask": "${defaultBuildTask}"
        }
    ],
    "tasks": {
        "version": "2.0.0",
        "tasks": [
            {
                "label": "Build",
                "type": "npm",
                "script": "build",
                "isBackground": false,
                "problemMatcher": ["$tsc"]
            },
            {
                "label": "Watch",
                "type": "npm",
                "script": "watch",
                "isBackground": true,
                "problemMatcher": ["$tsc-watch"]
            }
        ]
    }
}
