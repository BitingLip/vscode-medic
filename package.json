{
    "name": "vscode-medic",
    "displayName": "MEDIC",
    "description": "Watches for runtime errors and automatically resolves them with Copilot.",
    "version": "1.0.1",
    "publisher": "bitinglip",
    "license": "MIT",
    "icon": "resources/icon.png",
    "galleryBanner": {
        "color": "#1e1e1e",
        "theme": "dark"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/bitinglip/vscode-medic"
    },
    "bugs": {
        "url": "https://github.com/bitinglip/vscode-medic/issues"
    },
    "homepage": "https://github.com/bitinglip/vscode-medic#readme",
    "engines": {
        "vscode": "^1.93.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers",
        "Testing",
        "Chat",
        "Other"
    ],
    "keywords": [
        "copilot",
        "error",
        "debug",
        "runtime",
        "log",
        "watcher",
        "diagnostics",
        "ai",
        "autofix",
        "monitoring"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "errorPilot",
                    "title": "MEDIC",
                    "icon": "resources/icon.svg"
                }
            ]
        },
        "views": {
            "errorPilot": [
                {
                    "type": "webview",
                    "id": "errorPilot.view",
                    "name": "MEDIC"
                }
            ]
        },
        "commands": [
            {
                "command": "errorPilot.addWatcher",
                "title": "Add Watcher",
                "category": "MEDIC",
                "icon": "$(add)"
            },
            {
                "command": "errorPilot.removeWatcher",
                "title": "Remove Watcher",
                "category": "MEDIC",
                "icon": "$(trash)"
            },
            {
                "command": "errorPilot.sendError",
                "title": "Send to Copilot",
                "category": "MEDIC",
                "icon": "$(send)"
            },
            {
                "command": "errorPilot.dismissError",
                "title": "Dismiss Error",
                "category": "MEDIC",
                "icon": "$(close)"
            },
            {
                "command": "errorPilot.sendAllPending",
                "title": "Send All Pending",
                "category": "MEDIC",
                "icon": "$(send)"
            },
            {
                "command": "errorPilot.clearErrors",
                "title": "Clear All Errors",
                "category": "MEDIC",
                "icon": "$(clear-all)"
            },
            {
                "command": "errorPilot.toggleAutoTrigger",
                "title": "Toggle Auto-Trigger",
                "category": "MEDIC"
            },
            {
                "command": "errorPilot.scanWorkspace",
                "title": "Scan Workspace",
                "category": "MEDIC",
                "icon": "$(search)"
            },
            {
                "command": "errorPilot.openSettings",
                "title": "Settings",
                "category": "MEDIC",
                "icon": "$(settings-gear)"
            },
            {
                "command": "errorPilot.resolveError",
                "title": "Mark Error as Fixed",
                "category": "MEDIC",
                "icon": "$(pass)"
            },
            {
                "command": "errorPilot.markWorking",
                "title": "Mark Error as Working",
                "category": "MEDIC",
                "icon": "$(copilot)"
            },
            {
                "command": "errorPilot.markAttention",
                "title": "Mark Error as Needs Attention",
                "category": "MEDIC",
                "icon": "$(copilot-warning)"
            },
            {
                "command": "errorPilot.markAgentError",
                "title": "Mark Error as Agent Error",
                "category": "MEDIC",
                "icon": "$(copilot-error)"
            },
            {
                "command": "errorPilot.demoLifecycle",
                "title": "Demo: Error Lifecycle",
                "category": "MEDIC"
            }
        ],
        "menus": {
            "view/title": [
                {
                    "command": "errorPilot.addWatcher",
                    "when": "view == errorPilot.view",
                    "group": "navigation@1"
                },
                {
                    "command": "errorPilot.sendAllPending",
                    "when": "view == errorPilot.view",
                    "group": "navigation@2"
                },
                {
                    "command": "errorPilot.scanWorkspace",
                    "when": "view == errorPilot.view",
                    "group": "1_actions@1"
                },
                {
                    "command": "errorPilot.clearErrors",
                    "when": "view == errorPilot.view",
                    "group": "1_actions@2"
                },
                {
                    "command": "errorPilot.toggleAutoTrigger",
                    "when": "view == errorPilot.view",
                    "group": "2_config@1"
                },
                {
                    "command": "errorPilot.openSettings",
                    "when": "view == errorPilot.view",
                    "group": "2_config@2"
                }
            ]
        },
        "configuration": {
            "title": "MEDIC",
            "properties": {
                "errorPilot.agent": {
                    "type": "string",
                    "default": "@workspace",
                    "enum": [
                        "",
                        "@workspace",
                        "@terminal",
                        "@vscode"
                    ],
                    "enumDescriptions": [
                        "Default Copilot (no participant prefix)",
                        "@workspace — Full codebase context",
                        "@terminal — Terminal-focused",
                        "@vscode — VS Code API focused"
                    ],
                    "description": "Chat participant to prefix prompts with"
                },
                "errorPilot.autoTrigger": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically open Copilot chat when a new error is detected"
                },
                "errorPilot.debounceMs": {
                    "type": "number",
                    "default": 3000,
                    "minimum": 500,
                    "maximum": 30000,
                    "description": "Debounce time (ms) before auto-triggering Copilot after an error"
                },
                "errorPilot.promptTemplate": {
                    "type": "string",
                    "default": "Fix the following runtime error. Identify the root cause in the codebase and apply a fix.\n\nError from {source}:\n```\n{error}\n```\n\n{stackTrace}",
                    "editPresentation": "multilineText",
                    "description": "Prompt template. Variables: {source}, {error}, {file}, {line}, {raw}, {stackTrace}"
                },
                "errorPilot.maxQueueSize": {
                    "type": "number",
                    "default": 50,
                    "minimum": 10,
                    "maximum": 500,
                    "description": "Maximum number of errors to keep in the queue"
                },
                "errorPilot.approvalMode": {
                    "type": "string",
                    "default": "confirm",
                    "enum": [
                        "confirm",
                        "auto"
                    ],
                    "enumDescriptions": [
                        "Ask before applying changes",
                        "Automatically approve agent actions"
                    ],
                    "description": "Whether to auto-approve agent actions or require confirmation"
                },
                "errorPilot.autoDeleteSession": {
                    "type": "string",
                    "default": "never",
                    "enum": [
                        "never",
                        "done",
                        "5min"
                    ],
                    "enumDescriptions": [
                        "Never auto-delete",
                        "Delete when resolved",
                        "Delete 5 minutes after resolution"
                    ],
                    "description": "When to auto-delete agent sessions after resolution"
                },
                "errorPilot.chatMode": {
                    "type": "string",
                    "default": "agent",
                    "enum": [
                        "agent",
                        "ask",
                        "plan"
                    ],
                    "enumDescriptions": [
                        "Autonomous coding agent",
                        "Ask questions without edits",
                        "Plan before making changes"
                    ],
                    "description": "Default chat mode for sending errors"
                },
                "errorPilot.chatModel": {
                    "type": "string",
                    "default": "",
                    "description": "Preferred language model ID (empty = auto)"
                },
                "errorPilot.sessionMode": {
                    "type": "string",
                    "default": "new",
                    "enum": [
                        "new",
                        "active"
                    ],
                    "enumDescriptions": [
                        "Open a new chat session for each send",
                        "Send into the currently active chat session"
                    ],
                    "description": "Whether to open a new chat session or use the active one"
                },
                "errorPilot.watchdog.sentTimeoutMinutes": {
                    "type": "number",
                    "default": 2,
                    "minimum": 0.5,
                    "maximum": 60,
                    "description": "Minutes to wait for agent to start working before escalating to attention"
                },
                "errorPilot.watchdog.workingTimeoutMinutes": {
                    "type": "number",
                    "default": 10,
                    "minimum": 1,
                    "maximum": 120,
                    "description": "Minutes to wait for agent to finish before escalating to attention"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "node esbuild.js --production",
        "build": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "package": "vsce package"
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/vscode": "^1.93.0",
        "esbuild": "^0.21.0",
        "typescript": "^5.5.0"
    },
    "dependencies": {
        "@vscode/codicons": "^0.0.45"
    }
}
